@startuml "Checkout - 2PC Happy Path"

skinparam backgroundColor #FEFEFE
skinparam shadowing false

title Checkout - 2PC Happy Path

actor Client
participant "Nginx\nGateway" as GW
participant "Order Service\n(2PC Coordinator)" as Order
database "order-db\n(+ tx log)" as OrderDB

participant "Stock Service\n(Participant)" as Stock
database "stock-db" as StockDB

participant "Payment Service\n(Participant)" as Payment
database "payment-db" as PayDB

== 1. Initiate Checkout ==
Client -> GW : POST /orders/checkout/{order_id}
GW -> Order : POST /checkout/{order_id}
Order -> OrderDB : read order\n(items, user_id, total_cost)
Order -> OrderDB : CREATE tx:{tx_id}\nstate=STARTED

note right of Order
2PC Phases:
1. PREPARE (vote)
2. COMMIT / ABORT
end note

== 2. Phase 1: PREPARE (Voting) ==
Order -> OrderDB : tx:{tx_id} state=PREPARING

Order -> Stock : PREPARE reserve items
Stock -> StockDB : tentatively subtract stock
Stock --> Order : VOTE YES

Order -> Payment : PREPARE deduct payment
Payment -> PayDB : tentatively deduct credit
Payment --> Order : VOTE YES

note right of Order : All participants voted YES

== 3. Phase 2: COMMIT ==
Order -> OrderDB : tx:{tx_id} state=COMMITTING

Order -> Stock : COMMIT
Stock -> StockDB : finalize reservation

Order -> Payment : COMMIT
Payment -> PayDB : finalize deduction

== 4. Finalize ==
Order -> OrderDB : set order.paid = true
Order -> OrderDB : tx:{tx_id} state=COMPLETED

Order --> GW : 200 Checkout successful
GW --> Client : 200 Checkout successful

@enduml